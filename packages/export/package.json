{
  "name": "@opengrid/export",
  "version": "0.1.0",
  "license": "MIT",
  "description": "CSV and Excel export engine for OpenGrid",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "xlsx": "^0.18.5"
  },
  "peerDependenciesMeta": {
    "xlsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^1.0.0",
    "xlsx": "^0.18.5"
  }
}
